{
  "name": "@rwa-token-studio/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate --schema prisma/schema.prisma && tsx watch src/server.ts",
    "build": "prisma generate --schema prisma/schema.prisma && tsc -p tsconfig.json",
    "test": "prisma generate --schema prisma/schema.prisma && vitest run",
    "db:init": "prisma generate --schema prisma/schema.prisma && tsx prisma/init.ts",
    "db:seed": "prisma generate --schema prisma/schema.prisma && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@rwa-token-studio/domain": "0.1.0",
    "@fastify/cors": "^11.0.1",
    "@prisma/client": "6.10.1",
    "fastify": "^5.4.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "prisma": "6.10.1",
    "tsx": "^4.20.3"
  }
}
